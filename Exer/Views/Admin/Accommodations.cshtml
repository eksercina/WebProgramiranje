@model IEnumerable<Exer.Models.Accommodation>
@{ ViewBag.Title = "Svi objekti"; }
<h1>Svi objekti</h1><form method="get" class="filters"><select name="available"><option value="">Svi</option><option value="true">Dostupni</option><option value="false">Nedostupni</option></select><select name="sort"><option value="">Naziv rastuce</option><option value="name_desc">Naziv opadajuce</option><option value="price">Cena rastuce</option><option value="price_desc">Cena opadajuce</option><option value="date">Datum rastuce</option><option value="date_desc">Datum opadajuce</option></select><button>Primeni</button></form>
<table><tr><th>Naziv</th><th>Grad</th><th>Cena</th><th>Dostupan</th><th></th></tr>@foreach (var a in Model) { <tr><td>@a.Name</td><td>@a.City</td><td>@a.PricePerNight</td><td>@a.Available</td><td>@using (Html.BeginForm("ToggleAccommodation", "Admin", FormMethod.Post)) { <input type="hidden" name="id" value="@a.Id" /><button>Promeni dostupnost</button> } @using (Html.BeginForm("DeleteAccommodation", "Admin", new { id = a.Id }, FormMethod.Post)) { <button>Obrisi</button> }</td></tr> }</table>
